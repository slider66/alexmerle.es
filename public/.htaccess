# ── Security Headers ───────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  # Evita clickjacking
  Header always set X-Frame-Options "DENY"

  # Evita MIME-type sniffing
  Header always set X-Content-Type-Options "nosniff"

  # Controla referrer en navegación cross-origin
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # HSTS: fuerza HTTPS durante 1 año (solo enviar si el dominio tiene SSL estable)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # Limita acceso a features del navegador
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"

  # XSS Protection (legado, pero útil en IE/Edge antiguos)
  Header always set X-XSS-Protection "1; mode=block"

  # Content Security Policy
  # - default: solo self
  # - scripts: self + Google Analytics + unsafe-inline para Next.js hydration
  # - styles: self + unsafe-inline (Tailwind inline styles)
  # - images: self + data: (Next.js image placeholders)
  # - connect: self + Web3Forms + Google Analytics
  # - fonts: self (Geist via Next.js)
  Header always set Content-Security-Policy "\
default-src 'self'; \
script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com; \
style-src 'self' 'unsafe-inline'; \
img-src 'self' data: https://avatars.githubusercontent.com; \
font-src 'self'; \
connect-src 'self' https://api.web3forms.com https://www.google-analytics.com https://api.github.com; \
frame-ancestors 'none'; \
base-uri 'self'; \
form-action 'self' https://api.web3forms.com"
</IfModule>

# ── Cache-Control ──────────────────────────────────────────────────────────────
# HTML: sin caché — el navegador siempre pide la versión más reciente al servidor
<FilesMatch "\.(html)$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires "0"
</FilesMatch>

# Assets con hash (JS, CSS generados por Next.js): caché larga, son inmutables
<FilesMatch "\.(js|css)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Imágenes y fuentes: caché de 1 semana
<FilesMatch "\.(webp|png|jpg|jpeg|svg|ico|woff|woff2)$">
  Header set Cache-Control "public, max-age=604800"
</FilesMatch>

# ── Reescritura para rutas limpias (SPA-like con static export) ────────────────
Options -MultiViews
RewriteEngine On

# Redirige HTTP → HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Sirve archivos y carpetas existentes directamente
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Para rutas sin extensión, busca el .html equivalente
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]
