# Copia este archivo como .env.local y rellena los valores reales.
# NUNCA subas .env.local al repositorio.

# GitHub API — genera un token en https://github.com/settings/tokens
# Permisos mínimos necesarios: public_repo (lectura)
# Sin este token el portfolio carga solo los proyectos definidos en projectOverrides
GITHUB_TOKEN=

# Web3Forms — formulario de contacto (https://web3forms.com)
# Clave pública, segura en client-side
NEXT_PUBLIC_WEB3FORMS_KEY=
